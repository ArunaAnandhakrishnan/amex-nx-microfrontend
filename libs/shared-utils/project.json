{
  "name": "shared-utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "prefix": "amex",
  "sourceRoot": "libs/shared-utils/src",
  "tags": ["type:lib", "scope:shared"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/libs/shared-utils"],
      "options": { "project": "libs/shared-utils/ng-package.json" },
      "configurations": {
        "production":  { "tsConfig": "libs/shared-utils/tsconfig.lib.prod.json" },
        "development": { "tsConfig": "libs/shared-utils/tsconfig.lib.json" }
      },
      "defaultConfiguration": "production"
    },
    "lint": { "executor": "@nx/eslint:lint" }
  }
}
